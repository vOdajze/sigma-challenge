            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Produto Atualizado\",\n  \"descricao\": \"Descri\\u00e7\\u00e3o atualizada via Postman\",\n  \"preco\": 12345.67\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
