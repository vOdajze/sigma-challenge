{
  "info": {
    "_postman_id": "f61182f5-6afa-4cef-a69e-88f91f26ec78",
    "name": "Sigma Challenge API",
    "description": "Collection completa para testar todos os endpoints da API Sigma Challenge.\n\nExecute as requests na ordem listada para que as variáveis de ambiente sejam preenchidas automaticamente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Autenticação",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"admin\",\n  \"password\": \"Admin@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "pm.environment.set('token', res.access_token);",
                  "pm.test('Login OK', () => pm.response.to.have.status(200));",
                  "pm.test('Token recebido', () => pm.expect(res.access_token).to.be.a('string'));"
                ]
              }
            }
          ]
        }
      ]
    },
